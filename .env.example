# ---------------------------------------------------------------------------
# Docker image
# ---------------------------------------------------------------------------

BASE_IMAGE=zed_ros2_l4t_36.3.0_sdk_5.0.0
IMAGE_TAG=dev
CONTAINER_NAME=autonomypark-homebrew

# ---------------------------------------------------------------------------
# ROS 2 / DDS
# ---------------------------------------------------------------------------

ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# true:
#   Load config/fastdds/super_client_config.xml and connect as a
#   Fast DDS Discovery Server SUPER_CLIENT
#
# false:
#   Use normal Fast DDS discovery
USE_DISCOVERY_SERVER=true

# ---------------------------------------------------------------------------
# ZED camera
# ---------------------------------------------------------------------------

LAUNCH_ZED=true
ZED_MODEL=zed2i
ZED_CAMERA_NAME=zed
ZED_NAMESPACE=homebrew
ZED_SERIAL=12345678

# ---------------------------------------------------------------------------
# MAVROS
# ---------------------------------------------------------------------------

LAUNCH_MAVROS=true
FCU_URL=/dev/ttyFC:921600
MAVROS_NAMESPACE=homebrew
MAVROS_RESPAWN=true
