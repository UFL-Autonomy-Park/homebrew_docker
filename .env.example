# ---------------------------------------------------------------------------
# Docker image
# ---------------------------------------------------------------------------

BASE_IMAGE=zed_ros2_l4t_36.3.0_sdk_5.0.0
IMAGE_TAG=dev
CONTAINER_NAME=autonomypark-homebrew

# ---------------------------------------------------------------------------
# ROS 2 / DDS
# ---------------------------------------------------------------------------

ROS_DOMAIN_ID=0
ROS_LOCALHOST_ONLY=0
RMW_IMPLEMENTATION=rmw_fastrtps_cpp

# Leave empty to use normal DDS 
# Example: 192.168.1.201:11811
ROS_DISCOVERY_SERVER=192.168.1.201:11811

# ---------------------------------------------------------------------------
# ZED camera
# ---------------------------------------------------------------------------

LAUNCH_ZED=true
ZED_MODEL=zed2i
ZED_CAMERA_NAME=zed
ZED_NAMESPACE=

# ---------------------------------------------------------------------------
# MAVROS
# ---------------------------------------------------------------------------

LAUNCH_MAVROS=true
FCU_URL=/dev/ttyFC:921600
MAVROS_NAMESPACE=mavros
MAVROS_RESPAWN=true
